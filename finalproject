import cv2
import torch
import timm
import torch.nn as nn
from torchvision import transforms
import numpy as np

# Configuration
MODEL_PATH = 'outputs/best_model.pth'
BACKBONE = 'tf_efficientnet_b0'
IMAGE_SIZE = 224
DEVICE = 'cuda' if torch.cuda.is_available() else 'cpu'

# Define Model
class Classifier(nn.Module):
    def __init__(self, backbone=BACKBONE, num_classes=2):
        super().__init__()
        self.backbone = timm.create_model(backbone, pretrained=False, num_classes=0)
        self.fc = nn.Linear(self.backbone.num_features, num_classes)

    def forward(self, x):
        f = self.backbone(x)
        return self.fc(f)

# Load Model
ckpt = torch.load(MODEL_PATH, map_location=DEVICE)
classes = ckpt.get('classes', ['Normal', 'Skin Cancer'])
model = Classifier(num_classes=len(classes)).to(DEVICE)
model.load_state_dict(ckpt['model'])
model.eval()

# Preprocessing
transform = transforms.Compose([
    transforms.Resize((IMAGE_SIZE, IMAGE_SIZE)),
    transforms.ToTensor(),
    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])
])

# Start Camera
cap = cv2.VideoCapture(0)
if not cap.isOpened():
    print("❌ Cannot open camera.")
    exit()

print("✅ Real-time Skin Cancer Detection Started. Press 'q' to quit.")
while True:
    ret, frame = cap.read()
    if not ret:
        print("Frame read error.")
        break

    # Convert frame to PIL Image
    img_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    img_tensor = transform(transforms.ToPILImage()(img_rgb)).unsqueeze(0).to(DEVICE)

    # Predict
    with torch.no_grad():
        output = model(img_tensor)
        pred = output.argmax(1).item()
        label = classes[pred]
        prob = torch.softmax(output, dim=1)[0][pred].item()

    # Display
    color = (0, 255, 0) if label.lower() == 'normal' else (0, 0, 255)
    text = f"{label}: {prob*100:.2f}%"
    cv2.putText(frame, text, (20, 40), cv2.FONT_HERSHEY_SIMPLEX, 1, color, 2)
    cv2.imshow("Real-Time Skin Cancer Detection", frame)

    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()
